---
import Job from './Job.astro';

const jobs = [
  {
    title: 'Software Engineer — AI & Frontend Platform',
    company: 'Appfire Flow',
    companyNote: '(fka Pluralsight Flow)',
    location: 'Remote',
    period: 'Feb 2025 – Present',
    bullets: [
      'Lead frontend development on a customer-facing AI chatbot built on AWS Bedrock with a Python skills-based architecture; design the agent tool surface and skill invocations that embed LLM capabilities into the product.',
      'Architect agentic development workflows using structured CLAUDE.md configuration, workflow routing, scoped subagents, and per-feature task specs with verification checklists — reducing implementation drift and making AI-generated output auditable before merge.',
      'Drive post-acquisition package registry migration, consolidating all inherited Pluralsight packages into Appfire\'s ecosystem while maintaining cross-app compatibility across the React platform.',
      'Own Storybook-based design system end to end — contributing components, maintaining infrastructure, coordinating between product and design system teams, and ensuring the shared component library stays aligned across consuming applications.',
      'Lead ongoing React and dependency version migrations alongside state management and routing transitions, coordinating upgrades across a bounded-context architecture with module federation.',
    ],
  },
  {
    title: 'Software Engineer — Frontend Platform',
    company: 'Pluralsight Flow',
    location: 'Remote',
    period: 'Mar 2022 – Feb 2025',
    bullets: [
      'Extended and maintained the shared component library for the Flow BU, developing reusable widgets and standardizing components used across all customer-facing screens.',
      'Increased repository test coverage to a minimum of 70% by backfilling integration and unit tests (Jest, Cypress, React Testing Library); introduced accessibility testing and CI enforcement via axe-core, bringing all customer-facing routes to WCAG AA compliance.',
      'Led feature initiatives to develop, consolidate, and retire reports across the platform; presented alpha and beta releases to go-to-market stakeholders and drove delivery end to end.',
      'Delivered interactive data reports for user metrics and team performance, enabling data-driven insights across the platform\'s stakeholder base.',
      'Mentored interns and conducted frontend engineering interviews; served as teaching assistant for a Pluralsight × Year Up web development program.',
    ],
  },
  {
    title: 'Freelance Web Developer & Designer',
    company: 'Digital Brew LLC',
    location: 'Atlanta, GA',
    period: 'Oct 2018 – Jun 2023',
    bullets: [
      'Designed and developed responsive, SEO-optimized websites for local businesses, owning end-to-end client relationships from initial consultation through launch and ongoing support.',
      'Managed project scope, timelines, and delivery across concurrent client engagements using Next.js and React.',
    ],
  },
  {
    title: 'Full Stack Developer',
    company: 'MaxEx',
    location: 'Atlanta, GA',
    period: 'Feb 2020 – Jan 2022',
    bullets: [
      'Built, tested, and documented new and modified features across a .NET/Angular stack; researched system workflows and data usage to optimize, automate, and refactor existing business logic.',
    ],
  },
];
---

<section class="experience resume-section" aria-labelledby="experience-heading">
  <h2 class="section-label" id="experience-heading">Experience</h2>
  <div class="experience__list">
    {jobs.map((job) => <Job {...job} />)}
  </div>
</section>

<style>
  .experience__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
</style>
