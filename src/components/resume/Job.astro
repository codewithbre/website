---
interface Props {
  title: string;
  company?: string;
  companyNote?: string;
  location?: string;
  period: string;
  bullets: string[];
}

const { title, company, companyNote, location, period, bullets } = Astro.props;
---

<article class="job">
  <header class="job__header">
    <div class="job__meta">
      <h3 class="job__title">{title}</h3>
      {(company || location) && (
        <p class="job__company">
          {company && <strong>{company}</strong>}
          {companyNote && <span class="job__company-note">{companyNote}</span>}
          {company && location && <span class="job__sep" aria-hidden="true">&middot;</span>}
          {location && <span>{location}</span>}
        </p>
      )}
    </div>
    <time class="job__period">{period}</time>
  </header>
  <ul class="job__bullets" role="list">
    {bullets.map((b) => <li>{b}</li>)}
  </ul>
</article>

<style>
  .job {
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .job:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .job__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .job__title {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text-primary);
    line-height: 1.3;
  }

  .job__company {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-1);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .job__company strong {
    color: var(--color-text-primary);
  }

  .job__company-note {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .job__sep {
    color: var(--color-border);
  }

  .job__period {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 2px;
  }

  .job__bullets {
    list-style: disc;
    padding-left: 1em;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .job__bullets li {
    font-size: var(--text-sm);
    line-height: 1.65;
    color: var(--color-text-primary);
  }

  .job__bullets li::marker {
    color: var(--color-accent);
    font-size: 0.6em;
  }
</style>
