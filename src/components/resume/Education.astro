---
const education = [
  {
    degree: 'B.S. Computer Science',
    institution: 'Georgia State University',
    date: 'Dec 2019',
  },
  {
    degree: 'Professional Certificate — Geographic Information Systems',
    institution: 'Georgia State University',
    date: 'Dec 2019',
  },
];

const certifications = [
  {
    name: 'AWS Certified AI Practitioner',
    period: 'Dec 2024 – Dec 2027',
  },
];
---

<section class="education resume-section" aria-labelledby="education-heading">
  <h2 class="section-label" id="education-heading">Education & Certifications</h2>
  <div class="education__grid">
    <div>
      {education.map(({ degree, institution, date }) => (
        <div class="edu-item">
          <p class="edu-item__degree">{degree}</p>
          <p class="edu-item__meta">
            <span>{institution}</span>
            <span class="edu-item__sep" aria-hidden="true">&middot;</span>
            <time>{date}</time>
          </p>
        </div>
      ))}
    </div>
    <div>
      {certifications.map(({ name, period }) => (
        <div class="edu-item">
          <p class="edu-item__degree">{name}</p>
          <p class="edu-item__meta">
            <time>{period}</time>
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .education__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }

  .edu-item {
    padding-bottom: var(--space-4);
  }

  .edu-item__degree {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.4;
  }

  .edu-item__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-1);
    flex-wrap: wrap;
  }

  .edu-item__sep {
    color: var(--color-border);
  }

  @media (max-width: 600px) {
    .education__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
