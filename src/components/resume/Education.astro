---
import { education, certifications } from '../../data/education';
---

<section class="education resume-section" aria-labelledby="education-heading">
  <h2 class="section-label" id="education-heading">Education & Certifications</h2>
  <ul class="education__list" role="list">
    {education.map(({ degree, institution, date }) => (
      <li class="edu-item">
        <p class="edu-item__degree">{degree}</p>
        <p class="edu-item__meta">
          <span>{institution}</span>
          <span class="edu-item__sep" aria-hidden="true">&middot;</span>
          <time>{date}</time>
        </p>
      </li>
    ))}
    {certifications.map(({ name, period }) => (
      <li class="edu-item">
        <p class="edu-item__degree">{name}</p>
        <p class="edu-item__meta">
          <time>{period}</time>
        </p>
      </li>
    ))}
  </ul>
</section>

<style>
  .education__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .edu-item {
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .edu-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .edu-item__degree {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.4;
  }

  .edu-item__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-1);
    flex-wrap: wrap;
  }

  .edu-item__sep {
    color: var(--color-border);
  }
</style>
