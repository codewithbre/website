---
interface Props {
  role: string;
}

const { role } = Astro.props;
---

<div class="headline">
  <span class="headline__role mono-label">{role}</span>
</div>

<style>
  .headline {
    margin-bottom: var(--space-2);
  }

  .headline__role {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
    letter-spacing: 0.02em;
  }
</style>
