---
const skills: { category: string; items: string }[] = [
  { category: 'Languages & Frameworks', items: 'TypeScript, React, Python, C#, SQL, CSS, GraphQL, REST' },
  { category: 'AI & Agentic Systems', items: 'AWS Bedrock, AWS Strands, Skills-based architecture, Agentic workflow design, Claude Code, Cursor, GitHub Copilot' },
  { category: 'Frontend Platform', items: 'Module federation, Storybook, Vite, Webpack, Next.js, Nanostores, Component library authorship, Design systems' },
  { category: 'Testing & Quality', items: 'Jest, React Testing Library, Cypress, Playwright, axe-core, Vitest, WCAG AA' },
  { category: 'CI/CD & Tooling', items: 'GitHub Actions, Jenkins, Argo CD, Docker, Husky, lint-staged, Snyk, LaunchDarkly, DataDog' },
  { category: 'Infrastructure & Deployment', items: 'Vercel, Cloudflare Pages, Node.js, NPM/Yarn/pnpm, Git/GitHub' },
  { category: 'Design & CMS', items: 'Figma, TinaCMS, Sanity' },
];
---

<section class="skills resume-section" aria-labelledby="skills-heading">
  <h2 class="section-label" id="skills-heading">Technical Skills</h2>
  <dl class="skills__list">
    {skills.map(({ category, items }) => (
      <div class="skills__row">
        <dt class="skills__category">{category}</dt>
        <dd class="skills__items">{items}</dd>
      </div>
    ))}
  </dl>
</section>

<style>
  .skills__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .skills__row {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .skills__row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .skills__category {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding-top: 2px;
    line-height: 1.5;
  }

  .skills__items {
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    line-height: 1.65;
  }

  @media (max-width: 600px) {
    .skills__row {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
