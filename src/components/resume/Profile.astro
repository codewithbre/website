---
interface Props {
  sentences: string[];
}

const { sentences } = Astro.props;
---

<section class="profile resume-section" aria-labelledby="profile-heading">
  <h2 class="section-label" id="profile-heading">Profile</h2>
  {sentences.map((sentence) => (
    <p class="profile__text">{sentence}</p>
  ))}
</section>

<style>
  .profile__text {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--color-text-primary);
    max-width: 42rem;
  }
</style>
