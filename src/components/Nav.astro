---
const navLinks = [
  { href: '/resume', label: 'Resume' },
  { href: '/blog', label: 'Blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="nav-shell">
  <nav class="nav container container--wide" aria-label="Main navigation">
    <a href="/" class="nav__wordmark" aria-label="codewithbre home">
      codewithbre
    </a>
    <ul class="nav__links" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={['nav__link', { 'nav__link--active': currentPath.startsWith(href) }]}
            aria-current={currentPath.startsWith(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
    <button
      id="theme-toggle"
      class="theme-toggle"
      aria-label="Toggle color theme"
      type="button"
    >
      <svg class="icon icon--sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="icon icon--moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </nav>
</header>

<script>
  const toggle = document.getElementById('theme-toggle');

  function getTheme(): string {
    return document.documentElement.getAttribute('data-theme') ?? 'light';
  }

  function setTheme(theme: string): void {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
  }

  toggle?.addEventListener('click', () => {
    setTheme(getTheme() === 'dark' ? 'light' : 'dark');
  });
</script>

<style>
  .nav-shell {
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    height: 3.5rem;
  }

  .nav__wordmark {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  .nav__wordmark:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .nav__links {
    display: flex;
    list-style: none;
    gap: var(--space-6);
    margin-left: auto;
  }

  .nav__link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .nav__link:hover,
  .nav__link--active {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text-muted);
    cursor: pointer;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .theme-toggle:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-muted);
  }

  /* Show sun in dark mode, moon in light mode */
  :root[data-theme="dark"] .icon--moon,
  :root:not([data-theme="dark"]) .icon--sun {
    display: none;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .icon--moon {
      display: none;
    }
    :root:not([data-theme="light"]) .icon--sun {
      display: block;
    }
  }

  @media (max-width: 480px) {
    .nav__links {
      gap: var(--space-4);
    }
  }
</style>
