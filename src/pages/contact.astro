---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
---

<Base
  title="Contact — codewithbre"
  description="Get in touch with codewithbre."
>
  <div class="contact-page container">
    <div class="contact-header">
      <h1 class="contact-title">Get in touch</h1>
      <p class="contact-desc">Have a question or want to work together? Drop me a line.</p>
      <a href="mailto:codewithbre@gmail.com" class="contact-email">
        <Icon name="lucide:mail" size={16} aria-hidden="true" />
        codewithbre@gmail.com
      </a>
    </div>

    <form id="contact-form" class="contact-form" novalidate>
      <div class="form-group">
        <label for="name" class="form-label">Name</label>
        <input id="name" name="name" type="text" class="form-input" required autocomplete="name" />
      </div>

      <div class="form-group">
        <label for="email" class="form-label">Email</label>
        <input id="email" name="email" type="email" class="form-input" required autocomplete="email" />
      </div>

      <div class="form-group">
        <label for="message" class="form-label">Message</label>
        <textarea id="message" name="message" rows={6} class="form-input form-textarea" required></textarea>
      </div>

      <div id="form-status" class="form-status" role="alert" aria-live="polite" hidden></div>

      <button type="submit" id="submit-btn" class="form-submit">Send Message</button>
    </form>
  </div>
</Base>

<script>
  const FORMSPREE = 'https://formspree.io/f/xdkqlpzy';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusEl = document.getElementById('form-status') as HTMLDivElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    statusEl.hidden = true;
    statusEl.className = 'form-status';

    const data = {
      name: (form.elements.namedItem('name') as HTMLInputElement).value,
      email: (form.elements.namedItem('email') as HTMLInputElement).value,
      message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
    };

    try {
      const res = await fetch(FORMSPREE, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!res.ok) throw new Error('send failed');

      statusEl.textContent = 'Message sent. I will get back to you soon.';
      statusEl.classList.add('form-status--success');
      statusEl.hidden = false;
      form.reset();
    } catch {
      statusEl.textContent = 'Something went wrong. Try again or email me directly at codewithbre@gmail.com.';
      statusEl.classList.add('form-status--error');
      statusEl.hidden = false;
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>

<style>
  /* ── Entrance animations ── */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes status-in {
    from { opacity: 0; transform: translateY(-5px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Layout ── */
  .contact-page {
    padding-top: var(--space-16);
    padding-bottom: var(--space-24);
    max-width: 42rem;
  }

  /* ── Header ── */
  .contact-header {
    margin-bottom: var(--space-12);
    text-align: center;
  }

  @media (prefers-reduced-motion: no-preference) {
    .contact-header {
      animation: fade-up 0.4s ease both;
    }
  }

  .contact-title {
    font-size: clamp(1.75rem, 4vw, var(--text-3xl));
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  .contact-desc {
    margin-top: var(--space-3);
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .contact-email {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .contact-email:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  /* ── Form card ── */
  .contact-form {
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  @media (prefers-reduced-motion: no-preference) {
    .contact-form {
      animation: fade-up 0.4s ease both;
      animation-delay: 90ms;
    }
  }

  /* ── Fields ── */
  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .form-input {
    width: 100%;
    padding: 0.625rem var(--space-4);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text-primary);
    font-size: var(--text-sm);
    font-family: inherit;
    line-height: 1.5;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    outline: none;
  }

  .form-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 15%, transparent);
  }

  /* Override browser autofill blue — background-color alone cannot beat :-webkit-autofill */
  .form-input:-webkit-autofill,
  .form-input:-webkit-autofill:hover,
  .form-input:-webkit-autofill:focus {
    -webkit-text-fill-color: var(--color-text-primary);
    -webkit-box-shadow: 0 0 0 9999px var(--color-bg) inset;
    transition: background-color 9999s ease, box-shadow var(--transition-fast), border-color var(--transition-fast);
  }

  .form-textarea {
    resize: none;
  }

  /* ── Status message ── */
  .form-status {
    padding: var(--space-4);
    border-radius: 6px;
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .form-status--success {
    background-color: color-mix(in srgb, #22c55e 10%, transparent);
    color: #15803d;
    border: 1px solid color-mix(in srgb, #22c55e 30%, transparent);
  }

  .form-status--error {
    background-color: color-mix(in srgb, #ef4444 10%, transparent);
    color: #b91c1c;
    border: 1px solid color-mix(in srgb, #ef4444 30%, transparent);
  }

  :is([data-theme="dark"], :root:not([data-theme="light"])) .form-status--success {
    color: #86efac;
    background-color: color-mix(in srgb, #22c55e 12%, transparent);
    border-color: color-mix(in srgb, #22c55e 20%, transparent);
  }

  :is([data-theme="dark"], :root:not([data-theme="light"])) .form-status--error {
    color: #fca5a5;
    background-color: color-mix(in srgb, #ef4444 12%, transparent);
    border-color: color-mix(in srgb, #ef4444 20%, transparent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .form-status--success,
    .form-status--error {
      animation: status-in 0.2s ease both;
    }
  }

  /* ── Submit button ── */
  .form-submit {
    width: 100%;
    padding: var(--space-3) var(--space-6);
    background-color: var(--color-accent);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: 600;
    font-family: inherit;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition:
      background-color var(--transition-fast),
      transform 120ms ease,
      opacity var(--transition-fast);
  }

  .form-submit:hover:not(:disabled) {
    background-color: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .form-submit:active:not(:disabled) {
    transform: translateY(0);
  }

  .form-submit:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  @media (max-width: 520px) {
    .contact-form {
      padding: var(--space-6);
    }
  }
</style>
