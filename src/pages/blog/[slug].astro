---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base
  title={`${post.data.title} — codewithbre`}
  description={post.data.description}
>
  <article class="post-page container" aria-labelledby="post-title">
    <header class="post-header">
      <a href="/blog" class="back-link">&larr; Blog</a>
      <time class="post-date" datetime={post.data.publishDate.toISOString()}>
        {dateFormatter.format(post.data.publishDate)}
      </time>
      <h1 class="post-title" id="post-title">{post.data.title}</h1>
      <p class="post-description">{post.data.description}</p>
      {post.data.substackUrl && (
        <a
          href={post.data.substackUrl}
          class="substack-cta"
          target="_blank"
          rel="noopener noreferrer"
        >
          Read and follow on Substack &rarr;
        </a>
      )}
    </header>

    <div class="post-body">
      <Content />
    </div>

    {post.data.substackUrl && (
      <footer class="post-footer">
        <p class="post-footer__label">Enjoyed this?</p>
        <a
          href={post.data.substackUrl}
          class="substack-cta"
          target="_blank"
          rel="noopener noreferrer"
        >
          Follow codewithbre on Substack &rarr;
        </a>
      </footer>
    )}
  </article>
</Base>

<style>
  .post-page {
    padding-top: var(--space-12);
    padding-bottom: var(--space-24);
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-8);
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .post-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .post-date {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .post-title {
    font-size: clamp(1.5rem, 4vw, var(--text-3xl));
    line-height: 1.2;
    color: var(--color-text-primary);
  }

  .post-description {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 38rem;
  }

  .substack-cta {
    display: inline-block;
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .substack-cta:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }

  /* Post body prose styles */
  .post-body {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text-primary);
  }

  .post-body :global(h2) {
    font-size: var(--text-xl);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }

  .post-body :global(h3) {
    font-size: var(--text-lg);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .post-body :global(p) {
    margin-bottom: var(--space-6);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }

  .post-body :global(li) {
    margin-bottom: var(--space-2);
  }

  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-body :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-6);
    margin: var(--space-8) 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .post-body :global(pre) {
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: var(--space-6);
    overflow-x: auto;
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-12) 0;
  }

  .post-footer {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .post-footer__label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }
</style>
