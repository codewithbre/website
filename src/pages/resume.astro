---
import Base from '../layouts/Base.astro';
import Headline from '../components/resume/Headline.astro';
import Profile from '../components/resume/Profile.astro';
import Experience from '../components/resume/Experience.astro';
import Skills from '../components/resume/Skills.astro';
import Education from '../components/resume/Education.astro';
import '../styles/resume.css';
---

<Base
  title="Resume — codewithbre"
  description="AI Systems Engineer with 6+ years building production frontend and full stack applications. Specializing in agentic workflow architecture and frontend platform engineering."
>
  <div class="resume-page container">
    <div class="resume-header">
      <Headline
        role="AI Systems Engineer"
        location="Atlanta, GA"
      />
      <h1 class="resume-name">codewithbre</h1>
      <div class="resume-links">
        <a href="https://linkedin.com/in/codewithbre" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <span aria-hidden="true">&middot;</span>
        <a href="https://substack.com/@codewithbre" target="_blank" rel="noopener noreferrer">Substack</a>
        <span aria-hidden="true">&middot;</span>
        <a href="/resume.pdf" class="resume-download" download>Download PDF</a>
      </div>
    </div>

    <Profile text="AI Systems Engineer with 6+ years building production frontend and full stack applications. Specializes in agentic workflow architecture — designing the constraints, routing, and verification layers that make AI-assisted development reliable at scale. Brings product and design judgment into engineering decisions, operating across the full arc from ideation through tested, shipped code. Currently building customer-facing AI tools on AWS Bedrock; experienced in React platform engineering, design system ownership, shared package ecosystems, and cross-team frontend infrastructure." />
    <Experience />
    <Skills />
    <Education />
  </div>
</Base>

<style>
  .resume-page {
    padding-top: var(--space-16);
    padding-bottom: var(--space-24);
  }

  .resume-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .resume-name {
    font-family: var(--font-mono);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-top: var(--space-2);
    letter-spacing: -0.02em;
  }

  .resume-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-3);
    flex-wrap: wrap;
  }

  .resume-links a {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .resume-links a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .resume-links span {
    color: var(--color-border);
    font-size: var(--text-sm);
  }

  .resume-download {
    color: var(--color-accent) !important;
  }
</style>
