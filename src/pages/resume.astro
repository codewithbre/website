---
import Base from '../layouts/Base.astro';
import Headline from '../components/resume/Headline.astro';
import Profile from '../components/resume/Profile.astro';
import Experience from '../components/resume/Experience.astro';
import Skills from '../components/resume/Skills.astro';
import Education from '../components/resume/Education.astro';
import { Icon } from 'astro-icon/components';
import '../styles/resume.css';
---

<Base
  title="Resume — codewithbre"
  description="Frontend-focused software engineer building agentic AI solutions. Engineers the agentic layer: workflow design, constraints, and the verification logic that keeps AI solutions reliable. Engineers the frontend layer, centering architecture, accessibility, and user experience."
>
  <div class="resume-page container">
    <div class="resume-header">
      <Headline role="Software Engineer | Agentic AI Engineer" />
      <h1 class="resume-name">codewithbre</h1>
      <div class="resume-links">
        <a href="https://linkedin.com/in/codewithbre" target="_blank" rel="noopener noreferrer" class="resume-link">
          <Icon name="simple-icons:linkedin" size={13} aria-hidden="true" />
          LinkedIn
        </a>
        <span aria-hidden="true">&middot;</span>
        <a href="https://substack.com/@codewithbre" target="_blank" rel="noopener noreferrer" class="resume-link">
          <Icon name="simple-icons:substack" size={13} aria-hidden="true" />
          Substack
        </a>
        <span aria-hidden="true">&middot;</span>
        <a href="/codewithbre_resume.pdf" class="resume-link resume-download" download="codewithbre_resume.pdf">
          <Icon name="lucide:download" size={13} aria-hidden="true" />
          Download PDF
        </a>
      </div>
    </div>

    <Profile sentences={[
      'Frontend-focused software engineer building agentic AI solutions.',
      'Engineers the agentic layer: workflow design, constraints, and the verification logic that keeps AI solutions reliable.',
      'Engineers the frontend layer, centering architecture, accessibility, and user experience.',
    ]} />
    <Experience />
    <Skills />
    <Education />
  </div>
</Base>

<script>
  const sections = document.querySelectorAll<HTMLElement>('.resume-section');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.06, rootMargin: '0px 0px -24px 0px' }
  );

  sections.forEach((el) => {
    el.classList.add('will-reveal');
    observer.observe(el);
  });
</script>

<style>
  .resume-page {
    padding-top: var(--space-16);
    padding-bottom: var(--space-24);
  }

  .resume-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .resume-name {
    font-family: var(--font-mono);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-top: var(--space-2);
    letter-spacing: -0.02em;
  }

  .resume-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-3);
    flex-wrap: wrap;
  }

  .resume-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }

  .resume-links a {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .resume-links a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .resume-links span {
    color: var(--color-border);
    font-size: var(--text-sm);
  }

  .resume-download {
    color: var(--color-accent) !important;
  }
</style>
